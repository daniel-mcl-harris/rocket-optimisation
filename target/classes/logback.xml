<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress logging from OpenRocket packages -->
    <logger name="info.openrocket.core.database" level="WARN"/>
    <logger name="info.openrocket.core.startup.providers" level="WARN"/>
    <logger name="info.openrocket.core.util" level="WARN"/>
    <logger name="info.openrocket.core.simulation" level="WARN"/>
    <logger name="info.openrocket.core.preset" level="WARN"/>
    <logger name="info.openrocket.core.file" level="WARN"/>
    <logger name="info.openrocket" level="WARN"/>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
